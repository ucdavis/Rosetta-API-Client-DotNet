# Rosetta API Client Configuration
# Copy this file to .env and fill in your actual values
RosettaClient__TokenUrl=https://your-token-url/token
RosettaClient__TimeoutSeconds=30
RosettaClient__ClientSecret=your-client-secret-here
RosettaClient__ClientId=your-client-id-here
RosettaClient__BaseUrl=https://your-api-base-url/api/v1
RosettaClient__ApiVersion=v1
RosettaClient__Scope=read:public

# Test Data Configuration (optional - only needed for integration tests)
TestData__IamId=
TestData__IamIds=
TestData__LoginId=
TestData__ManagerIamId=
TestData__AccountId=
TestData__EmployeeId=
TestData__StudentId=
TestData__TestEmail=
TestData__TestDisplayName=
TestData__EnableDebugLogging=false
TestData__DebugResponseMaxLength=40000
